{
  "seed": 11,
  "output_dir": "artifacts/phase5/policy_seed_v1",
  "data": {
    "dataset_path": "artifacts/datasets/phase5_policy_seed_v1",
    "train_split": "train",
    "validation_split": "validation"
  },
  "model": {
    "hidden_dim": 128,
    "hidden_layers": 2,
    "dropout": 0.1
  },
  "optimization": {
    "epochs": 10,
    "batch_size": 16,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "legality_loss_weight": 1.0,
    "policy_loss_weight": 1.0
  },
  "evaluation": {
    "legality_threshold": 0.5
  },
  "export": {
    "bundle_dir": "models/proposer/policy_seed_v1",
    "checkpoint_name": "checkpoint.pt",
    "exported_program_name": "proposer.pt2",
    "metadata_name": "metadata.json"
  }
}
